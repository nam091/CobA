# ==============================================================================
# CobA — environment variables (sample)
# ==============================================================================
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# ------------------------------------------------------------------------------

# --- LLM providers (Hybrid: cloud + local) --------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXX

# --- OpenAI / Anthropic-compatible endpoints (optional) -------------------------
# When set, the corresponding provider routes through this base URL instead of
# the vendor default. This unlocks any OpenAI-compatible gateway:
#   * OpenRouter:   https://openrouter.ai/api/v1
#   * Together:     https://api.together.xyz/v1
#   * Groq:         https://api.groq.com/openai/v1
#   * DeepSeek:     https://api.deepseek.com/v1
#   * Mistral:      https://api.mistral.ai/v1
#   * Fireworks:    https://api.fireworks.ai/inference/v1
#   * Ollama /v1:   http://localhost:11434/v1   (also exposes OpenAI-compatible)
#   * vLLM / LiteLLM / TGI: your own URL
# Pair with COBA_LLM_DETECTOR / COBA_LLM_VERIFIER below to pick model ids that
# match what the gateway exposes (e.g. "qwen2.5-coder", "deepseek-coder",
# "meta-llama/Llama-3.1-8B-Instruct").
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# ANTHROPIC_BASE_URL=https://your-anthropic-relay.example.com

# Local LLM via Ollama native /api/chat protocol (separate from the /v1 shim above)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# --- LLM routing policy ---------------------------------------------------------
# detector | verifier | retriever  →  model id
COBA_LLM_DETECTOR=gpt-4o-mini
COBA_LLM_VERIFIER=claude-3-5-sonnet-20241022
COBA_LLM_OFFLINE_FALLBACK=qwen2.5-coder:7b

# Daily budget (USD). Router blocks if exceeded.
COBA_LLM_DAILY_BUDGET_USD=5.0

# Per-scan budget (USD). Orchestrator skips remaining chunks when this is hit.
# Set to 0 to disable the per-scan cap.
COBA_SCAN_BUDGET_USD=2.0

# Skip-cache: reuse findings for unchanged files (hashed by content sha256).
COBA_SKIP_CACHE_ENABLED=true

# --- Tool paths (override if not on $PATH) --------------------------------------
SEMGREP_BIN=semgrep
JOERN_BIN=joern
JOERN_PARSE_BIN=joern-parse
BANDIT_BIN=bandit
GITLEAKS_BIN=gitleaks

# --- API server -----------------------------------------------------------------
COBA_HOST=0.0.0.0
COBA_PORT=8000
COBA_LOG_LEVEL=INFO

# --- RAG vector store -----------------------------------------------------------
CHROMA_PERSIST_DIR=.coba_data/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Misc -----------------------------------------------------------------------
COBA_MAX_FILE_SIZE_KB=512
COBA_MAX_CHUNK_TOKENS=2000
COBA_PARALLEL_LLM_CALLS=4
